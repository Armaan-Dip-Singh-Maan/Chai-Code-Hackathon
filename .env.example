# ADMIN_RESET_SECRET=

DB_HOST=localhost
DB_PORT=5432
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password_or_blank
DB_NAME=sql_class_2_db
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT_MS=0
DB_IDLE_TIMEOUT_MS=0
